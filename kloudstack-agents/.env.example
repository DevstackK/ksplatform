# KloudStack Agent Tokens
# Copy this file to .env and fill in every value.
# NEVER commit .env to git.

# ── GitHub ──────────────────────────────────────────────────────────────────
# Scopes needed: repo, read:org
# Get it: github.com/settings/tokens
GITHUB_TOKEN=

# ── Vercel ──────────────────────────────────────────────────────────────────
# Get it: vercel.com/account/tokens
VERCEL_TOKEN=

# ── Netlify ─────────────────────────────────────────────────────────────────
# Get it: app.netlify.com/user/applications → Personal access tokens
NETLIFY_TOKEN=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Use the SECRET key (sk_live_...), not the publishable key.
# Get it: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Atlassian (Jira / Confluence) ───────────────────────────────────────────
# Get token: id.atlassian.com/manage-profile/security → API tokens
# ATLASSIAN_BASE_URL is your workspace URL, e.g. https://kloudstack.atlassian.net
ATLASSIAN_TOKEN=
ATLASSIAN_EMAIL=urfanazad@googlemail.com
ATLASSIAN_BASE_URL=

# ── Google Workspace (Gmail, Calendar) ──────────────────────────────────────
# Create OAuth credentials: console.cloud.google.com → APIs & Services → Credentials
# Scopes: gmail.send, gmail.readonly, calendar.events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Microsoft 365 (Outlook, Teams, Calendar) ────────────────────────────────
# Register app: portal.azure.com → App registrations
# Permissions: Mail.Send, Calendars.ReadWrite, Team.ReadBasic.All
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Canva ───────────────────────────────────────────────────────────────────
# Get it: canva.com/developers → Create an integration
CANVA_TOKEN=

# ── Adobe ───────────────────────────────────────────────────────────────────
# Create app: developer.adobe.com → Console → Projects
# Services needed: Firefly API, Photoshop API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# ── HeyGen ──────────────────────────────────────────────────────────────────
# Get it: app.heygen.com/settings → API
HEYGEN_TOKEN=

# ── Lucid ───────────────────────────────────────────────────────────────────
# Get it: lucid.app/settings → Developer → API keys
LUCID_TOKEN=

# ── Miro ────────────────────────────────────────────────────────────────────
# Get it: miro.com/app/settings/user-profile/apps → Create app
MIRO_TOKEN=

# ── Descript ────────────────────────────────────────────────────────────────
# Get it: descript.com/settings → Integrations
DESCRIPT_TOKEN=

# ── DocuSign ────────────────────────────────────────────────────────────────
# Get it: admindemo.docusign.com → Apps and Keys
# DOCUSIGN_ACCOUNT_ID is the API Account ID shown on that page
DOCUSIGN_TOKEN=
DOCUSIGN_ACCOUNT_ID=

# ── PayPal ──────────────────────────────────────────────────────────────────
# Create app: developer.paypal.com → My Apps & Credentials → Live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
