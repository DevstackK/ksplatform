{
  "mcpServers": {
    "marketplace": {
      "type": "http",
      "url": "https://ksplatform.vercel.app/api/mcp",
      "headers": {
        "x-api-key": "${MARKETPLACE_API_KEY}"
      }
    },
    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server:latest"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}" }
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp-adapter@0.3.2", "stdio"],
      "env": { "VERCEL_TOKEN": "${VERCEL_TOKEN}" }
    },
    "netlify": {
      "command": "npx",
      "args": ["-y", "@netlify/mcp@1.15.1"],
      "env": { "NETLIFY_TOKEN": "${NETLIFY_TOKEN}" }
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/agent-toolkit@0.9.0", "mcp"],
      "env": { "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}" }
    },
    "paypal": {
      "command": "npx",
      "args": ["-y", "@paypal/mcp@1.8.1"],
      "env": { "PAYPAL_CLIENT_ID": "${PAYPAL_CLIENT_ID}", "PAYPAL_CLIENT_SECRET": "${PAYPAL_CLIENT_SECRET}" }
    },
    "heygen": {
      "command": "npx",
      "args": ["-y", "heygen-mcp-server@1.1.0"],
      "env": { "HEYGEN_API_KEY": "${HEYGEN_TOKEN}" }
    },
    "lucid": {
      "command": "npx",
      "args": ["-y", "lucid-mcp-server@0.1.5"],
      "env": { "LUCID_TOKEN": "${LUCID_TOKEN}" }
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "atlassian-mcp@0.1.5"],
      "env": { "ATLASSIAN_TOKEN": "${ATLASSIAN_TOKEN}", "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}", "ATLASSIAN_BASE_URL": "${ATLASSIAN_BASE_URL}" }
    },
    "microsoft-365": {
      "command": "npx",
      "args": ["-y", "microsoft-mcp-server@0.1.0"],
      "env": { "MICROSOFT_TENANT_ID": "${MICROSOFT_TENANT_ID}", "MICROSOFT_CLIENT_ID": "${MICROSOFT_CLIENT_ID}", "MICROSOFT_CLIENT_SECRET": "${MICROSOFT_CLIENT_SECRET}" }
    },
    "google-workspace": {
      "type": "http",
      "url": "https://drivemcp.googleapis.com/mcp/v1",
      "headers": { "Authorization": "Bearer ${GOOGLE_TOKEN}" }
    },
    "gmail": {
      "type": "http",
      "url": "https://gmailmcp.googleapis.com/mcp/v1",
      "headers": { "Authorization": "Bearer ${GOOGLE_TOKEN}" }
    },
    "google-calendar": {
      "type": "http",
      "url": "https://calendarmcp.googleapis.com/mcp/v1",
      "headers": { "Authorization": "Bearer ${GOOGLE_TOKEN}" }
    },
    "canva": {
      "type": "http",
      "url": "https://mcp.canva.com/mcp",
      "headers": { "Authorization": "Bearer ${CANVA_TOKEN}" }
    },
    "adobe": {
      "type": "http",
      "url": "https://adobe-creativity.adobe.io/mcp",
      "headers": { "Authorization": "Bearer ${ADOBE_CLIENT_SECRET}", "x-api-key": "${ADOBE_CLIENT_ID}" }
    },
    "miro": {
      "type": "http",
      "url": "https://mcp.miro.com",
      "headers": { "Authorization": "Bearer ${MIRO_TOKEN}" }
    },
    "descript": {
      "type": "http",
      "url": "https://api.descript.com/v2/mcp/claude",
      "headers": { "Authorization": "Bearer ${DESCRIPT_TOKEN}" }
    },
    "docusign": {
      "type": "http",
      "url": "https://mcp.docusign.com/mcp",
      "headers": { "Authorization": "Bearer ${DOCUSIGN_TOKEN}", "x-account-id": "${DOCUSIGN_ACCOUNT_ID}" }
    }
  }
}
